@model VeterinerKlinik.Models.Hayvan

@{
    ViewData["Title"] = "Hayvan Detay";
}

<h2>Hayvan Detayı</h2>

<dl class="row">
    <dt class="col-sm-3">Ad</dt>
    <dd class="col-sm-9">@Model.Ad</dd>

    <dt class="col-sm-3">Kategori</dt>
    <dd class="col-sm-9">@Model.Kategori</dd>

    <dt class="col-sm-3">Tür</dt>
    <dd class="col-sm-9">@Model.Tur</dd>

    <dt class="col-sm-3">Cins</dt>
    <dd class="col-sm-9">@Model.Cins</dd>

    <dt class="col-sm-3">Yaş</dt>
    <dd class="col-sm-9">@Model.Yas</dd>

    <dt class="col-sm-3">Müşteri</dt>
    <dd class="col-sm-9">@Model.MusteriAdi</dd>

    <dt class="col-sm-3">Bakım Bilgisi</dt>
    <dd class="col-sm-9">
        <span class="badge bg-info text-dark">@Model.BakimBilgisi()</span>
    </dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Düzenle</a>
<a asp-action="Index" class="btn btn-secondary">Geri Dön</a>