@model VeterinerKlinik.Models.Hayvan

@{
    ViewData["Title"] = "Hayvan Düzenle";
}

<h2>Hayvan Düzenle</h2>

<form method="post" asp-action="Edit">
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="mb-3">
        <label>Müşteri Adı</label>
        <input name="MusteriAdi" class="form-control" value="@Model.MusteriAdi" required />
    </div>

    <div class="mb-3">
        <label>Hayvan Adı</label>
        <input name="Ad" class="form-control" value="@Model.Ad" required />
    </div>

    <div class="mb-3">
        <label>Yaş</label>
        <input name="Yas" type="number" class="form-control" value="@Model.Yas" required />
    </div>

    <div class="mb-3">
        <label>Kategori</label>
        <select name="Kategori" id="kategoriSecim" class="form-select" onchange="kategoriGoster()">
            <option value="">-- Seçin --</option>
            <option value="Evcil" selected="@(Model.Kategori == "Evcil")">Evcil</option>
            <option value="Çiftlik" selected="@(Model.Kategori == "Çiftlik")">Çiftlik</option>
            <option value="Egzotik" selected="@(Model.Kategori == "Egzotik")">Egzotik</option>
        </select>
    </div>

    <div class="mb-3" id="bolum-tur">
        <label>Tür</label>
        <select name="Tur" id="turSecim" class="form-select" onchange="cinsGoster()">
            <option value="">-- Seçin --</option>
        </select>
    </div>

    <div class="mb-3" id="bolum-cins">
        <label>Cins</label>
        <select name="Cins" id="cinsSecim" class="form-select">
            <option value="">-- Seçin --</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>

<script>
const turler = {
    "Evcil":   ["Kedi", "Köpek", "Kuş"],
    "Çiftlik": ["Tavuk", "İnek", "Keçi"],
    "Egzotik": ["Yılan", "Maymun", "Balık", "Van Gölü Canavarı"]
};

    const cinsler = {
            "Kedi":   ["Bengal", "Ragdoll", "Van Kedisi"],
            "Köpek":  ["Border Collie", "Labrador", "Alman Çoban Köpeği"],
            "Kuş":    ["Muhabbet Kuşu", "Sultan Papağanı", "Kanarya"],
            "Tavuk":  ["Brahma", "Leghorn", "Sultan Tavuğu"],
            "İnek":   ["Jersey", "Simmental", "Angus"],
            "Keçi":   ["Saanen", "Ankara Keçisi", "Boer"],
            "Yılan":  ["Kara Mamba", "Mısır Yılanı", "Kral Piton"],
            "Maymun": ["Makak", "Capuchin", "Marmoset"],
            "Balık":  ["Silver Arowana", "Koi", "Beta"],
            "Van Gölü Canavarı": []
        };

const mevcutTur = "@Model.Tur";
const mevcutCins = "@Model.Cins";

function kategoriGoster() {
    const kategori = document.getElementById("kategoriSecim").value;
    const turSelect = document.getElementById("turSecim");
    const cinsSelect = document.getElementById("cinsSecim");

    turSelect.innerHTML = '<option value="">-- Seçin --</option>';
    cinsSelect.innerHTML = '<option value="">-- Seçin --</option>';

    if (kategori && turler[kategori]) {
        turler[kategori].forEach(t => {
            const opt = document.createElement("option");
            opt.value = t;
            opt.text = t;
            if (t === mevcutTur) opt.selected = true;
            turSelect.appendChild(opt);
        });
    }

    if (mevcutTur) cinsGoster();
}

function cinsGoster() {
    const tur = document.getElementById("turSecim").value;
    const cinsSelect = document.getElementById("cinsSecim");

    cinsSelect.innerHTML = '<option value="">-- Seçin --</option>';

    if (tur && cinsler[tur]) {
        cinsler[tur].forEach(c => {
            const opt = document.createElement("option");
            opt.value = c;
            opt.text = c;
            if (c === mevcutCins) opt.selected = true;
            cinsSelect.appendChild(opt);
        });
    }
}

window.onload = function() {
    kategoriGoster();
};
</script>