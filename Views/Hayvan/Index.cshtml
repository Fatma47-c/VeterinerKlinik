@model List<Hayvan>

<h2>Hayvanlar</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ Yeni Hayvan</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Tür</th>
            <th>Yaş</th>
            <th>Müşteri</th>
            <th>Özel Bilgi</th>
            <th>Sesi</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>

        @foreach (var h in Model)
        {
            <tr>
                <td>@h.Ad</td>
                <td>
                    @if (h is Kedi)
                    {
                        <span class="badge bg-warning">🐱 Kedi</span>
                    }
                    else if (h is Kopek)
                    {

                        <span class="badge bg-info">🐶 Köpek</span>
                    }
                    else if (h is Kus)
                    {

                        <span class="badge bg-success">🐦 Kuş</span>
                    }
                </td>
                <td>@h.Yas</td>
                <td>@h.Musteri?.Ad</td>
                <td>
                    @if (h is Kopek kp)
                    {

                        <span>Irk: @kp.Irk | Boyut: @kp.Boyut</span>
                    }
                </td>
                <td><strong>@h.SesCikar()</strong></td>
                <td>
                    <a asp-action="Details" asp-route-id="@h.Id" class="btn btn-sm btn-secondary">Detay</a>
                    <a asp-action="Edit" asp-route-id="@h.Id" class="btn btn-sm btn-warning">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@h.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
            
        }
    </tbody>
</table>