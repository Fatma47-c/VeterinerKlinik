<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VeterinerKlinik</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/minty/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
            body {
    background: linear-gradient(135deg, #f8fffe 0%, #f0f9f4 50%, #fafffe 100%);
    min-height: 100vh;
                 }

            .card {
                border-radius: 16px;
            }

            .navbar-brand {
                font-size: 1.4rem;
            }

            .btn {
                border-radius: 10px;
            }

            .form-control, .form-select {
                border-radius: 10px;
            }

            footer {
                background-color: #f0f9f4;
            }
            .navbar-nav .nav-link {
    color: rgba(255, 255, 255, 0.95) !important;
    font-weight: 500;
}

.navbar-nav .nav-link:hover {
    color: white !important;
    text-shadow: 0 0 8px rgba(255,255,255,0.6);
}

.navbar-brand {
    color: white !important;
    font-size: 1.4rem;
    font-weight: 700;
}
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-success mb-4 shadow">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    🐾 VeterinerKlinik
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">🏠 Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Hayvan" asp-action="Index">🐾 Hayvanlar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Randevu" asp-action="Index">📅 Randevular</a>
                        </li>
                        <li class="nav-item">
                         <a class="nav-link" asp-controller="Veteriner" asp-action="Index">👨‍⚕️ Hekimlerimiz</a>
                       </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - 🐾 VeterinerKlinik - Tüm Hakları Saklıdır
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>