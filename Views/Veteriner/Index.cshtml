@model List<VeterinerKlinik.Models.Veteriner>

@{
    ViewData["Title"] = "Hekimlerimiz";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h2 class="fw-bold">👨‍⚕️ Hekimlerimiz</h2>
        <p class="text-muted">Deneyimli ve uzman kadromuzla dostlarınıza en iyi hizmeti sunuyoruz.</p>
    </div>

    <div class="row justify-content-center">
        @foreach (var v in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow border-0 text-center p-4" style="border-radius:20px;">
                    <div class="mb-3" style="font-size: 80px;">
                        @if (v.Ad != null && v.Ad.Contains("Selin"))
                        {
                            <span>👩‍⚕️</span>
                        }
                        else
                        {
                            <span>👨‍⚕️</span>
                        }
                    </div>
                    <h5 class="fw-bold">@v.Ad @v.Soyad</h5>
                    <p class="text-muted mb-1">@v.UzmanlikAlani</p>
                    <hr />
                    @if (v.Ad != null && v.Ad.Contains("Selin"))
                    {
                        <p class="small text-muted">🎓 Ankara Üniversitesi Veteriner Fakültesi</p>
                        <p class="small text-muted">📅 10 yıl deneyim</p>
                        <p class="small text-muted">🏅 Küçük Hayvan Cerrahisi Uzmanlığı</p>
                    }
                    else if (v.Ad != null && v.Ad.Contains("Ahmet"))
                    {
                        <p class="small text-muted">🎓 İstanbul Üniversitesi Veteriner Fakültesi</p>
                        <p class="small text-muted">📅 7 yıl deneyim</p>
                        <p class="small text-muted">🏅 Çiftlik Hayvanları Sağlığı Uzmanlığı</p>
                    }
                    else if (v.Ad != null && v.Ad.Contains("Murat"))
                    {
                        <p class="small text-muted">🎓 Selçuk Üniversitesi Veteriner Fakültesi</p>
                        <p class="small text-muted">📅 12 yıl deneyim</p>
                        <p class="small text-muted">🏅 Egzotik Hayvan Sağlığı Uzmanlığı</p>
                    }
                </div>
            </div>
        }
    </div>
</div>