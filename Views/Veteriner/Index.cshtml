@model List<VeterinerKlinik.Models.Veteriner>

@{
    ViewData["Title"] = "Hekimlerimiz";
}

<div class="container mt-4">

    <!-- BAŞLIK -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">👨‍⚕️ Hekimlerimiz</h2>
        <p class="text-muted">
            Deneyimli ve uzman kadromuzla dostlarınıza en iyi hizmeti sunuyoruz.
        </p>
    </div>

    <!-- ÜST SAĞ -->
    <div class="text-end mb-3">
        @if (Context.Session.GetString("Admin") == "true")
        {
            <a asp-action="AdminPanel" class="btn btn-dark">⚙️ Admin Panel</a>
            <a asp-action="AdminCikis" class="btn btn-outline-danger">🚪 Çıkış</a>
        }
        else
        {
            <a asp-action="AdminGiris" class="btn btn-outline-secondary">🔐 Yönetici Girişi</a>
        }
    </div>

    <!-- KARTLAR -->
    <div class="row justify-content-center">
        @foreach (var v in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow border-0 text-center p-4" style="border-radius:20px;">

                    <div class="mb-3" style="font-size: 80px;">
                        <span>@(v.Cinsiyet == "K" ? "👩‍⚕️" : "👨‍⚕️")</span>
                    </div>

                    <h5 class="fw-bold">@v.Ad @v.Soyad</h5>
                    <p class="text-muted mb-1">@v.UzmanlikAlani</p>

                    <hr />

                    <p class="small text-muted">🎓 @v.Universite</p>
                    <p class="small text-muted">📅 @v.DeneyimYili yıl deneyim</p>
                    <p class="small text-muted">🏅 @v.Unvan</p>

                </div>
            </div>
        }
    </div>
</div>