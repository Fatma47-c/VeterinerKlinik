@{
    ViewData["Title"] = "Yeni Randevu";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0">📅 Yeni Randevu Oluştur</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-action="Create">

                        <div class="mb-3">
                            <label class="form-label fw-bold">👤 Müşteri Adı</label>
                            <input name="MusteriAdi" class="form-control" required autocomplete="off"
                                   placeholder="Adınızı giriniz" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">📞 Telefon</label>
                            <input name="Telefon" class="form-control" maxlength="10" required
                                   placeholder="5XXXXXXXXX" autocomplete="off"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                            <div class="form-text text-muted">0 girmeden 10 haneli giriniz. Örnek: 5321234567</div>
                            <div class="form-text text-danger" id="telefonHata" style="display:none">
                                Telefon numarası 10 haneli ve sadece rakam olmalıdır.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">🐾 Kategori</label>
                            <select id="kategoriSecim" class="form-select" onchange="kategoriGoster()">
                                <option value="">-- Seçin --</option>
                                <option value="Evcil">🏠 Evcil</option>
                                <option value="Çiftlik">🌾 Çiftlik</option>
                                <option value="Egzotik">🌴 Egzotik</option>
                            </select>
                        </div>

                        <div class="mb-3" id="bolum-tur" style="display:none">
                            <label class="form-label fw-bold">🔍 Hayvan Türü</label>
                            <select name="HayvanTuru" id="turSecim" class="form-select" onchange="cinsGoster()" required>
                                <option value="">-- Seçin --</option>
                            </select>
                        </div>

                        <div class="mb-3" id="bolum-cins" style="display:none">
                            <label class="form-label fw-bold">🧬 Hayvan Cinsi</label>
                            <select name="HayvanCinsi" id="cinsSecim" class="form-select">
                                <option value="">-- Seçin --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">📆 Randevu Tarih ve Saati</label>
                            <div class="form-text text-muted mb-1">Kliniğe gelmek istediğiniz tarih ve saati seçiniz.</div>
                            <input name="Tarih" type="datetime-local" class="form-control"
                                   id="tarihInput" required />
                            <div class="form-text text-danger" id="tarihHata" style="display:none">
                                Geçmiş tarih seçilemez.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">👨‍⚕️ Veteriner</label>
                            <select name="VeterinerId" class="form-select" required>
                                <option value="">-- Seçin --</option>
                                @foreach (var v in ViewBag.Veterinerler)
                                {
                                    <option value="@v.Id">@v.Ad @v.Soyad - @v.UzmanlikAlani</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">📝 Açıklama</label>
                            <textarea name="Aciklama" class="form-control" rows="3"
                                      placeholder="Ek bilgi girebilirsiniz..."></textarea>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-success w-100">✅ Kaydet</button>
                            <a asp-action="Index" class="btn btn-outline-secondary w-100">❌ İptal</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const turler = {
        "Evcil":   ["Kedi", "Köpek", "Kuş"],
        "Çiftlik": ["Tavuk", "İnek", "Keçi"],
        "Egzotik": ["Yılan", "Maymun", "Balık", "Van Gölü Canavarı"]
    };

    const cinsler = {
        "Kedi":   ["Bengal", "Ragdoll", "Van Kedisi"],
        "Köpek":  ["Border Collie", "Labrador", "Alman Çoban Köpeği"],
        "Kuş":    ["Muhabbet Kuşu", "Sultan Papağanı", "Kanarya"],
        "Tavuk":  ["Brahma", "Leghorn", "Sultan Tavuğu"],
        "İnek":   ["Jersey", "Simmental", "Angus"],
        "Keçi":   ["Saanen", "Ankara Keçisi", "Boer"],
        "Yılan":  ["Kara Mamba", "Mısır Yılanı", "Kral Piton"],
        "Maymun": ["Makak", "Capuchin", "Marmoset"],
        "Balık":  ["Silver Arowana", "Koi", "Beta"],
        "Van Gölü Canavarı": []
    };

    function kategoriGoster() {
        const kategori = document.getElementById("kategoriSecim").value;
        const turSelect = document.getElementById("turSecim");
        const cinsSelect = document.getElementById("cinsSecim");

        turSelect.innerHTML = '<option value="">-- Seçin --</option>';
        cinsSelect.innerHTML = '<option value="">-- Seçin --</option>';
        document.getElementById("bolum-cins").style.display = "none";

        if (kategori && turler[kategori]) {
            turler[kategori].forEach(t => {
                const opt = document.createElement("option");
                opt.value = t;
                opt.text = t;
                turSelect.appendChild(opt);
            });
            document.getElementById("bolum-tur").style.display = "block";
        } else {
            document.getElementById("bolum-tur").style.display = "none";
        }
    }

    function cinsGoster() {
        const tur = document.getElementById("turSecim").value;
        const cinsSelect = document.getElementById("cinsSecim");

        cinsSelect.innerHTML = '<option value="">-- Seçin --</option>';

        if (tur && cinsler[tur]) {
            if (cinsler[tur].length === 0) {
                document.getElementById("bolum-cins").style.display = "none";
                return;
            }
            cinsler[tur].forEach(c => {
                const opt = document.createElement("option");
                opt.value = c;
                opt.text = c;
                cinsSelect.appendChild(opt);
            });
            document.getElementById("bolum-cins").style.display = "block";
        } else {
            document.getElementById("bolum-cins").style.display = "none";
        }
    }

    const tarihInput = document.getElementById("tarihInput");
    const simdi = new Date();
    const pad = n => String(n).padStart(2, "0");
    const minTarih = `${simdi.getFullYear()}-${pad(simdi.getMonth()+1)}-${pad(simdi.getDate())}T${pad(simdi.getHours())}:${pad(simdi.getMinutes())}`;
    tarihInput.min = minTarih;

    document.querySelector("form").addEventListener("submit", function(e) {
        let gecerli = true;

        const telefon = document.querySelector("[name='Telefon']").value;
        const telefonHata = document.getElementById("telefonHata");
        if (!/^[0-9]{10}$/.test(telefon)) {
            telefonHata.style.display = "block";
            gecerli = false;
        } else {
            telefonHata.style.display = "none";
        }

        const tarih = new Date(tarihInput.value);
        const tarihHata = document.getElementById("tarihHata");
        if (tarih < new Date()) {
            tarihHata.style.display = "block";
            gecerli = false;
        } else {
            tarihHata.style.display = "none";
        }

        if (!gecerli) e.preventDefault();
    });
</script>